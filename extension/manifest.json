{
  "manifest_version": 3,
  "name": "SaleNoti — Theo dõi giá Shopee",
  "version": "0.1.0",
  "description": "Bấm '+ Theo dõi giá' trên trang sản phẩm Shopee → nhận email khi giá giảm. Affiliate disclosure đầy đủ — chúng tôi không tự áp coupon, không override cookie KOC khác.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/48.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*.shopee.vn/*", "https://salenoti.vn/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.shopee.vn/*-i.*.*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["disclosure-card.html"],
      "matches": ["*://*.shopee.vn/*"]
    }
  ]
}
