    "test": "vitest run --passWithNoTests",
    "test:e2e": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "esbuild": "^0.24.0",
    "eslint": "^9.10.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "vitest": "^2.1.0"
  }
}
