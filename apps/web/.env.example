# SaleNoti web env shape — populate real values through Doppler or your secret manager.
# Never commit .env, .env.local, .env.production, or real credential values.

APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Auth.js / Google OAuth (FR-AUTH-001..003)
AUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_SECRET_N_MINUS_1=
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret

# Data stores used by auth/session and protected app flows
MONGODB_URI=mongodb+srv://user:password@cluster.example/salenoti
REDIS_URL=rediss://default:password@example.upstash.io:6380

# Extension CORS/session handoff (FR-AUTH-003 / FR-EXT-001)
EXT_ID=replace-after-chrome-web-store-publish

# Observability (FR-OBS-001)
SENTRY_DSN_WEB=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PII_SALT=replace-with-openssl-rand-hex-32
