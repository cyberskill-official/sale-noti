{
  "name": "salenoti",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,md,yml,yaml}\"",
    "fr:check": "node scripts/fr-check.mjs",
    "legal:check": "node scripts/legal-check.mjs"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "prettier": "3.8.3",
    "turbo": "2.9.14",
    "typescript": "6.0.3"
  }
}
