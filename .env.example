# SaleNoti env shape — populated from Doppler (NEVER commit real values)
# Run: `doppler setup` then `doppler run -- pnpm dev`

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
GIT_COMMIT=local-dev
ADMIN_TOKEN=                                # ops-only X-Admin-Token for protected API bypasses; openssl rand -hex 32

# ─── Auth (FR-AUTH-001/002/003) ───────────────────────────────────────────────
AUTH_SECRET=                                # min 32 chars; openssl rand -hex 32
DATA_ENCRYPTION_KEY=                         # 32-byte hex for AES-256-GCM envelopes; openssl rand -hex 32
DATA_ENCRYPTION_KEY_ID=local-v1
PII_HASH_SALT=                               # openssl rand -hex 32
GOOGLE_CLIENT_ID=                            # from Google Cloud Console OAuth consent screen
GOOGLE_CLIENT_SECRET=
EXT_ID=                                      # Chrome extension id (post-publish)

# ─── Data (FR-AFF/PRICE/WATCH/ADMIN-004) ─────────────────────────────────────
MONGODB_URI=mongodb+srv://...                # (deprecated in P3; kept for backward compat) Atlas M0 region
MONGO_URI_SG=mongodb+srv://salenoti:***@salenoti-sg-primary.xvxyz.mongodb.net/?replicaSet=rs0&retryWrites=true&w=majority  # FR-ADMIN-004: Singapore primary
MONGO_URI_US=mongodb+srv://salenoti:***@salenoti-us-east.xvxyz.mongodb.net/?replicaSet=rs0&retryWrites=true&w=primaryPreferred  # FR-ADMIN-004: US East secondary
MONGO_POOL_SIZE=50                           # FR-ADMIN-004: max connections per region (default 50)
MONGO_MAX_POOL_SIZE_MB=128                   # FR-ADMIN-004: memory limit for all pools (MB, default 128)
MONGO_DEBUG=false                            # FR-ADMIN-004: enable connection logs (true|false)
TIMESCALE_DB_URL=postgres://...              # Neon Postgres + Timescale extension
REDIS_URL=rediss://default:...@...upstash.io:6380   # Upstash SG

# ─── Mobile API routing (FR-ADMIN-004) ───────────────────────────────────────
EXPO_PUBLIC_SALENOTI_API_BASE_URL=http://localhost:3000    # shared fallback for mobile
EXPO_PUBLIC_SALENOTI_API_BASE_URL_SG=http://localhost:3000 # mobile routes to SG-facing API base when locale is SEA
EXPO_PUBLIC_SALENOTI_API_BASE_URL_US=http://localhost:3000 # mobile routes to US-facing API base when locale is non-SEA

# ─── Shopee Affiliate (FR-AFF-001..004) ───────────────────────────────────────
SHOPEE_AFFILIATE_APP_ID=                     # from affiliate.shopee.vn dashboard
SHOPEE_AFFILIATE_APP_SECRET=
SHOPEE_RATE_LIMIT_PER_MIN=1000               # default; tune after confirming with Shopee PM
DEEPLINK_SALT=                               # min 32 chars; openssl rand -hex 32

# ─── Email + Push + Telegram (FR-NOTIF-001..003) ──────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_IDEM_SALT=                             # openssl rand -hex 32
EMAIL_HASH_SALT=                             # defaults to PII_HASH_SALT only in local tests; set explicitly in envs
UNSUB_SALT=                                  # openssl rand -hex 32
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_LINK_SALT=

# ─── Billing (FR-BILL-001) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# ─── Growth (FR-GROW-001) ─────────────────────────────────────────────────────
REFERRAL_SALT=                               # openssl rand -hex 32

# ─── OBS (FR-OBS-001 + FR-WORKER-001) ─────────────────────────────────────────
SENTRY_DSN_WEB=
SENTRY_DSN_API=
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PII_SALT=
BULL_BOARD_USER=ops
BULL_BOARD_PASS=                             # openssl rand -hex 24
BETTER_STACK_TOKEN=
SLACK_OBS_WEBHOOK=https://hooks.slack.com/services/...
